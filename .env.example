# Chiave Google Gemini (consigliata: ~€0.16/annuncio) — aistudio.google.com
GEMINI_API_KEY=...

# Chiave OpenAI (alternativa: ~€0.80/annuncio) — platform.openai.com
# OPENAI_API_KEY=sk-...

# --- Opzionali ---

# Provider AI: gemini (default se c'è GEMINI_API_KEY) | openai
# AI_PROVIDER=gemini

# Qualità immagini gpt-image-1: high (default, massima fedeltà) | medium (più economico)
# IMAGE_QUALITY=high

# Su un server pubblico: true = ogni utente deve fornire la propria chiave OpenAI
# (la chiave del server non viene mai usata dalle richieste web)
# REQUIRE_CLIENT_KEY=true

# Password d'accesso all'app (consigliata quando l'app è online):
# chi non la conosce non può generare annunci
# APP_PASSWORD=una-password-a-tua-scelta

# Browser Playwright per la pubblicazione: true su server senza display
# (default: visibile su Windows, headless altrove)
# PLAYWRIGHT_HEADLESS=true

# Dopo quanti giorni cancellare le immagini generate (default 14)
# GENERATED_MAX_AGE_DAYS=14

# Massimo annunci generabili per IP ogni ora (protezione costi API).
# Default 12, 0 = nessun limite
# RATE_LIMIT_PER_HOUR=12
